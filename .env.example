# lite-task environment variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Base URL of your lite-task instance
LITE_TASK_URL=http://localhost:8011

# Telegram bot token — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID — only this user can interact with the bot.
# Find it by messaging @userinfobot on Telegram.
BOT_HOST_ID=

# AI provider — Anthropic takes priority if both are set
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
