# lite-task environment variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Base URL of your lite-task instance (used by the Telegram bot to reach the API)
LITE_TASK_URL=http://localhost:8011

# ── Database ──────────────────────────────────────────────────────────────────
# Optional: Turso cloud database.
# If both vars are set, the app uses Turso instead of the local SQLite file.
# Leave blank (or omit) to use local SQLite at data/task-light.db.
TURSO_DB_URL=
TURSO_API_KEY=

# ── Telegram bot ──────────────────────────────────────────────────────────────
# Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID — only this user can interact with the bot.
# Find it by messaging @userinfobot on Telegram.
BOT_HOST_ID=

# ── AI provider ───────────────────────────────────────────────────────────────
# Anthropic takes priority if both are set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Retell API key ──────────────────────────────────────────────────────────────
# Retell is used if you want to use voice call with your agent
RETELL_API_KEY=