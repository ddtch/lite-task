{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "local": "vite --port 8012",
    "build": "vite build",
    "start": "deno serve -A --port=8011 _fresh/server.js",
    "preview": "deno task build && deno task start",
    "update": "deno run -A -r jsr:@fresh/update .",
    "mcp": "deno run -A mcp/server.ts",
    "mcp:http": "deno run -A mcp/http-client.ts",
    "compile-mcp": "deno compile -A --output lite-task-mcp mcp/http-client.ts",
    "bot": "deno run -A --env-file=.env bot/main.ts",
    "calls:setup": "deno run -A --env-file=.env calls/setup.ts",
    "calls:update-url": "deno run -A --env-file=.env calls/update-url.ts",
    "calls:scheduler": "deno run -A --env-file=.env calls/scheduler.ts",
    "events:scheduler": "deno run -A --env-file=.env calls/event-scheduler.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "@fullcalendar/core": "npm:@fullcalendar/core@^6.1.20",
    "@fullcalendar/daygrid": "npm:@fullcalendar/daygrid@^6.1.20",
    "@fullcalendar/timegrid": "npm:@fullcalendar/timegrid@^6.1.20",
    "@fullcalendar/interaction": "npm:@fullcalendar/interaction@^6.1.20",
    "@fullcalendar/multimonth": "npm:@fullcalendar/multimonth@^6.1.20",
    "@types/node": "npm:@types/node@^25.3.0",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.27.0",
    "grammy": "npm:grammy@^1.36.1",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.52.0",
    "openai": "npm:openai@^4.96.0",
    "@libsql/client": "npm:@libsql/client@^0.14.0",
    "@libsql/client/web": "npm:@libsql/client@^0.14.0/web",
    "retell-client-js-sdk": "npm:retell-client-js-sdk@^2.0.0"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
