{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A --port=8011 _fresh/server.js",
    "preview": "deno task build && deno task start",
    "update": "deno run -A -r jsr:@fresh/update .",
    "mcp": "deno run -A mcp/server.ts",
    "mcp:http": "deno run -A mcp/http-client.ts",
    "compile-mcp": "deno compile -A --output lite-task-mcp mcp/http-client.ts",
    "bot": "deno run -A --env-file=.env bot/main.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "@types/node": "npm:@types/node@^25.3.0",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.27.0",
    "grammy": "npm:grammy@^1.36.1",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.52.0",
    "openai": "npm:openai@^4.96.0"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
